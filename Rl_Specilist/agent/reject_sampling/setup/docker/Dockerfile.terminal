# TerminalTraj 终端沙箱镜像
# 用于在 Docker 容器内执行 bash 命令，隔离环境
FROM ubuntu:22.04

# 基础工具
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash coreutils findutils grep sed gawk \
    python3 python3-pip \
    git curl wget vim less file \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# 常用 Python 包（TerminalTraj 任务可能需要）
RUN pip3 install --no-cache-dir \
    requests \
    beautifulsoup4 \
    lxml \
    numpy

# 工作目录
WORKDIR /workspace

# 非 root 用户（安全）
RUN useradd -m -s /bin/bash agent
USER agent

# 默认 bash
CMD ["/bin/bash"]
